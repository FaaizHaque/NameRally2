{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "env": {
        "FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT": "120",
        "FASTLANE_XCODEBUILD_SETTINGS_RETRIES": "5"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
