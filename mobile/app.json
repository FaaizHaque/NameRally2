{
  "expo": {
    "name": "NAPT",
    "slug": "namerally",
    "scheme": "namerally",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./src/assets/logo-main.png",
    "splash": {
      "backgroundColor": "#F5EDD8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haquegames.napt",
      "buildNumber": "106",
      "infoPlist": {
        "CFBundleDisplayName": "NAPT",
        "NSMicrophoneUsageDescription": "NAPT uses the microphone for audio features.",
        "NSCalendarsUsageDescription": "NAPT needs access to your calendar.",
        "NSCalendarsFullAccessUsageDescription": "NAPT needs full calendar access.",
        "NSRemindersUsageDescription": "NAPT needs access to reminders.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.haquegames.napt"
    },
    "plugins": [
      "./plugins/withPatchGoogleAdsCodegen",
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-1431240801280221~1971859778"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "NAPT uses the microphone for audio features."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/logo-main.png",
          "color": "#4ADE80",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
