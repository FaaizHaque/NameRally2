{
  "expo": {
    "name": "NameRally",
    "slug": "namerally",
    "scheme": "namerally",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./src/assets/logo-main.png",
    "splash": {
      "image": "./src/assets/logo-main.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.haquegames.napt",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "NameRally uses the microphone for audio features.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.haquegames.napt"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "NameRally uses the microphone for audio features."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
